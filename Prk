/**
 * GitHub Tree Service
 * Handles file tree navigation and content retrieval
 */

const axios = require('axios');
const authService = require('./github-auth-service');

const API_BASE = 'https://api.github.com';

class GitHubTreeService {
  /**
   * Get file tree for a repository at a specific path
   */
  async getTree(owner, repo, path = '', branch = null) {
    const headers = authService.getHeaders();
    const ref = branch || await this.getDefaultBranch(owner, repo);
    
    // Get the tree recursively for the path
    const treePath = path ? `/${path}` : '';
    const response = await axios.get(
      `${API_BASE}/repos/${owner}/${repo}/contents${treePath}?ref=${ref}`,
      { headers }
    );

    // Handle single file response
    if (!Array.isArray(response.data)) {
      return {
        type: 'file',
        content: this.parseFileContent(response.data)
      };
    }

    // Sort: directories first, then files
    const items = response.data.sort((a, b) => {
      if (a.type === b.type) {
        return a.name.localeCompare(b.name);
      }
      return a.type === 'dir' ? -1 : 1;
    });

    return {
      type: 'directory',
      items: items.map(item => this.parseTreeItem(item, owner, repo, ref))
    };
  }

  /**
   * Parse tree item from GitHub API response
   */
  parseTreeItem(item, owner, repo, branch) {
    return {
      name: item.name,
      path: item.path,
      type: item.type === 'dir' ? 'folder' : 'file',
      size: item.size || 0,
      sha: item.sha,
      url: item.html_url,
      downloadUrl: item.download_url,
      gitUrl: item.git_url,
      owner,
      repo,
      branch
    };
  }

  /**
   * Parse file content from GitHub API response
   */
  parseFileContent(data) {
    return {
      name: data.name,
      path: data.path,
      type: 'file',
      size: data.size || 0,
      sha: data.sha,
      url: data.html_url,
      downloadUrl: data.download_url,
      gitUrl: data.git_url,
      content: data.content,
      encoding: data.encoding
    };
  }

  /**
   * Get file content
   */
  async getFileContent(owner, repo, path, branch = null) {
    const headers = authService.getHeaders();
    const ref = branch || await this.getDefaultBranch(owner, repo);
    
    const response = await axios.get(
      `${API_BASE}/repos/${owner}/${repo}/contents/${path}?ref=${ref}`,
      { headers }
    );

    const data = response.data;
    
    // Decode base64 content if present
    let content = null;
    if (data.content && data.encoding === 'base64') {
      content = Buffer.from(data.content, 'base64').toString('utf-8');
    }

    return {
      name: data.name,
      path: data.path,
      type: 'file',
      size: data.size || 0,
      sha: data.sha,
      url: data.html_url,
      downloadUrl: data.download_url,
      content: content,
      encoding: data.encoding,
      branch: ref
    };
  }

  /**
   * Get default branch
   */
  async getDefaultBranch(owner, repo) {
    const headers = authService.getHeaders();
    
    const response = await axios.get(
      `${API_BASE}/repos/${owner}/${repo}`,
      { headers }
    );

    return response.data.default_branch;
  }

  /**
   * Get raw file URL
   */
  getRawUrl(owner, repo, path, branch = 'main') {
    return `https://raw.githubusercontent.com/${owner}/${repo}/${branch}/${path}`;
  }
}

