 */

class TransferSystem {
  constructor() {
    this.transfers = [];
    this.onTransferStart = null;
    this.onTransferComplete = null;
    this.onTransferError = null;
  }

  /**
   * Transfer file from Storage to GitHub
   */
  async storageToGitHub(fileInfo, targetRepo, targetPath, options = {}) {
    const transferId = this.createTransferId();
    
    try {
      this.notifyStart(transferId, {
        direction: 'storage-to-github',
        source: fileInfo,
        target: { repo: targetRepo, path: targetPath }
      });

      // Step 1: Download file from storage
      const fileContent = await this.downloadFromStorage(fileInfo);
      
      // Step 2: Upload to GitHub
      const result = await githubApi.saveFile(
        targetRepo.owner,
        targetRepo.name,
        targetPath,
        fileContent,
        options.message || `Add ${fileInfo.name} via file manager`,
        options.branch
      );

      this.notifyComplete(transferId, result);
      return result;
    } catch (error) {
      this.notifyError(transferId, error);
      throw error;
    }
  }

  /**
   * Transfer file from GitHub to Storage
   */
  async githubToStorage(fileInfo, targetPath, options = {}) {
    const transferId = this.createTransferId();
    
    try {
      this.notifyStart(transferId, {
        direction: 'github-to-storage',
        source: fileInfo,
        target: { path: targetPath }
      });

      // Step 1: Download file from GitHub
      const fileContent = await this.downloadFromGitHub(fileInfo);
      
      // Step 2: Upload to storage (via API)
      const result = await this.uploadToStorage(targetPath, fileContent, fileInfo.name);

      this.notifyComplete(transferId, result);
      return result;
    } catch (error) {
      this.notifyError(transferId, error);
      throw error;
    }
  }

  /**
   * Download file from storage
   */
  async downloadFromStorage(fileInfo) {
    const response = await fetch(`/api/storage/download?source=${fileInfo.source}&path=${encodeURIComponent(fileInfo.path)}`);
    
    if (!response.ok) {
      throw new Error('Failed to download from storage');
    }

    const blob = await response.blob();
    return blob;
  }

  /**
   * Download file from GitHub
   */
  async downloadFromGitHub(fileInfo) {
    if (fileInfo.downloadUrl) {
      const response = await fetch(fileInfo.downloadUrl);
      if (!response.ok) {
        throw new Error('Failed to download from GitHub');
      }
      return await response.text();
    }

    // Fallback: get content via API
    const content = await githubApi.getContent(
      fileInfo.owner,
      fileInfo.repo,
      fileInfo.path,
      fileInfo.branch
    );

    return content.content;
  }

  /**
   * Upload to storage
   */
  async uploadToStorage(path, content, filename) {
    const formData = new FormData();
    const blob = content instanceof Blob ? content : new Blob([content]);
    formData.append('files', blob, filename);

    // This would need to be adapted to the existing session upload API
    const sessionId = window.workspace?.currentSession?.id;
    if (!sessionId) {
      throw new Error('No active session');
    }

    const response = await fetch(`/api/sessions/${sessionId}/files`, {
      method: 'POST',
      body: formData
    });

    if (!response.ok) {
      throw new Error('Failed to upload to storage');
    }

    return await response.json();
  }

