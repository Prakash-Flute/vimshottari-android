   */
  createTransferId() {
    return `transfer_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
  }

  /**
   * Notify transfer start
   */
  notifyStart(transferId, info) {
    this.transfers.push({ id: transferId, status: 'in-progress', info });
    if (this.onTransferStart) {
      this.onTransferStart(transferId, info);
    }
  }

  /**
   * Notify transfer complete
   */
  notifyComplete(transferId, result) {
    const transfer = this.transfers.find(t => t.id === transferId);
    if (transfer) {
      transfer.status = 'completed';
      transfer.result = result;
    }
    if (this.onTransferComplete) {
      this.onTransferComplete(transferId, result);
    }
  }

  /**
   * Notify transfer error
   */
  notifyError(transferId, error) {
    const transfer = this.transfers.find(t => t.id === transferId);
    if (transfer) {
      transfer.status = 'error';
      transfer.error = error;
    }
    if (this.onTransferError) {
      this.onTransferError(transferId, error);
    }
  }

  /**
   * Get transfer status
   */
  getTransferStatus(transferId) {
    return this.transfers.find(t => t.id === transferId);
  }

  /**
   * Get all transfers
   */
  getAllTransfers() {
    return [...this.transfers];
  }

  /**
   * Clear completed transfers
   */
  clearCompleted() {
    this.transfers = this.transfers.filter(t => t.status === 'in-progress');
  }
}

