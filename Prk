    if (['js', 'ts', 'jsx', 'tsx'].includes(ext)) {
      this.highlightJavaScript(codeContentEl);
    } else if (['html', 'xml'].includes(ext)) {
      this.highlightHTML(codeContentEl);
    } else if (ext === 'css') {
      this.highlightCSS(codeContentEl);
    }
