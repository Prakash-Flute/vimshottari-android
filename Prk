/**
 * GitHub File Service
 * Handles file operations: create, update, delete
 */

const axios = require('axios');
const authService = require('./github-auth-service');

const API_BASE = 'https://api.github.com';

class GitHubFileService {
  /**
   * Create or update a file
   */
  async saveFile(owner, repo, path, content, message, branch = null, sha = null) {
    const headers = authService.getHeaders();
    const ref = branch || await this.getDefaultBranch(owner, repo);
    
    // Encode content to base64
    const encodedContent = Buffer.from(content).toString('base64');
    
    const body = {
      message: message || `Update ${path} via file manager`,
      content: encodedContent,
      branch: ref
    };
    
    // Include sha if updating existing file
    if (sha) {
      body.sha = sha;
    }
    
    const response = await axios.put(
      `${API_BASE}/repos/${owner}/${repo}/contents/${path}`,
      body,
      { headers }
    );

    return {
      success: true,
      commit: response.data.commit.sha,
      content: {
        name: response.data.content.name,
        path: response.data.content.path,
        sha: response.data.content.sha,
        size: response.data.content.size,
        url: response.data.content.html_url
      }
    };
  }

  /**
   * Delete a file
   */
  async deleteFile(owner, repo, path, sha, message, branch = null) {
    const headers = authService.getHeaders();
    const ref = branch || await this.getDefaultBranch(owner, repo);
    
    const body = {
      message: message || `Delete ${path} via file manager`,
      sha: sha,
      branch: ref
    };
    
    await axios.delete(
      `${API_BASE}/repos/${owner}/${repo}/contents/${path}`,
      { headers, data: body }
    );

    return {
      success: true,
      message: `Deleted ${path}`
    };
  }

  /**
   * Rename/move a file
   */
  async renameFile(owner, repo, oldPath, newPath, sha, message, branch = null) {
    const headers = authService.getHeaders();
    const ref = branch || await this.getDefaultBranch(owner, repo);
    
    // Get current content
    const contentResponse = await axios.get(
      `${API_BASE}/repos/${owner}/${repo}/contents/${oldPath}?ref=${ref}`,
      { headers }
    );
    
    const content = Buffer.from(contentResponse.data.content, 'base64').toString('utf-8');
    
    // Create new file
    await this.saveFile(owner, repo, newPath, content, 
      message || `Rename ${oldPath} to ${newPath}`, ref);
    
    // Delete old file
    await this.deleteFile(owner, repo, oldPath, sha, 
      `Delete ${oldPath} (renamed to ${newPath})`, ref);

    return {
      success: true,
      message: `Renamed ${oldPath} to ${newPath}`
    };
  }

  /**
   * Get file SHA for updates/deletes
   */
  async getFileSha(owner, repo, path, branch = null) {
    const headers = authService.getHeaders();
    const ref = branch || await this.getDefaultBranch(owner, repo);
    
    const response = await axios.get(
      `${API_BASE}/repos/${owner}/${repo}/contents/${path}?ref=${ref}`,
      { headers }
    );

    return response.data.sha;
  }

  /**
   * Get default branch
   */
  async getDefaultBranch(owner, repo) {
    const headers = authService.getHeaders();
    
    const response = await axios.get(
      `${API_BASE}/repos/${owner}/${repo}`,
      { headers }
    );

    return response.data.default_branch;
  }
}

module.exports = new GitHubFileService();

