 * Handles GitHub API errors consistently
 */

/**
 * GitHub API Error Handler
 */
const handleGitHubError = (error, req, res, next) => {
  // Check if it's a GitHub API error
  if (error.response) {
    const status = error.response.status;
    const message = error.response.data?.message || error.message;
    
    switch (status) {
      case 401:
        return res.status(401).json({
          error: 'Unauthorized',
          message: 'GitHub authentication failed. Please check your token.',
          details: message
        });
        
      case 403:
        return res.status(403).json({
          error: 'Forbidden',
          message: 'Access denied or rate limit exceeded.',
          details: message
        });
        
      case 404:
        return res.status(404).json({
          error: 'Not Found',
          message: 'The requested resource was not found.',
          details: message
        });
        
      case 422:
        return res.status(422).json({
          error: 'Validation Failed',
          message: 'The request could not be processed.',
          details: message
        });
        
      default:
        return res.status(status).json({
          error: 'GitHub API Error',
          message: message,
          status
        });
    }
  }
  
  // Pass to next error handler if not a GitHub API error
  next(error);
};

module.exports = {
  handleGitHubError
};

