/**
 * Properties Dialog UI
 * Shows file/folder properties
 */

class PropertiesDialogUI {
  constructor() {
    this.modal = null;
  }

  /**
   * Show properties dialog
   */
  show(item, options = {}) {
    this.createModal(item, options);
    this.bindEvents();
  }

  /**
   * Create modal
   */
  createModal(item, options) {
    this.modal = document.createElement('div');
    this.modal.className = 'properties-dialog-modal';
    
    const isFolder = item.type === 'folder';
    const title = isFolder ? 'Folder Properties' : 'File Properties';
    
    this.modal.innerHTML = `
      <div class="properties-dialog-overlay"></div>
      <div class="properties-dialog-container">
        <div class="properties-dialog-header">
          <h3>${title}</h3>
          <button class="btn-icon close-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
        <div class="properties-dialog-content">
          <div class="property-row">
            <span class="property-label">Name</span>
            <span class="property-value" data-copy="${item.name}">${item.name}</span>
          </div>
          <div class="property-row">
            <span class="property-label">Path</span>
            <span class="property-value path-value" data-copy="${item.path}">${item.path}</span>
          </div>
          <div class="property-row">
            <span class="property-label">Type</span>
            <span class="property-value">${isFolder ? 'Folder' : this.getFileType(item.name)}</span>
          </div>
          ${!isFolder ? `
            <div class="property-row">
              <span class="property-label">Size</span>
              <span class="property-value">${this.formatBytes(item.size)}</span>
            </div>
          ` : ''}
          ${item.sha ? `
            <div class="property-row">
              <span class="property-label">SHA</span>
              <span class="property-value sha-value" data-copy="${item.sha}">${item.sha.substring(0, 7)}...</span>
            </div>
          ` : ''}
          ${item.modifiedAt ? `
            <div class="property-row">
              <span class="property-label">Modified</span>
              <span class="property-value">${this.formatDate(item.modifiedAt)}</span>
            </div>
          ` : ''}
        </div>
        <div class="properties-dialog-footer">
          <button class="btn-secondary close-btn-footer">Close</button>
        </div>
      </div>
    `;

    document.body.appendChild(this.modal);
  }

  /**
   * Bind events
   */
  bindEvents() {
    const overlay = this.modal.querySelector('.properties-dialog-overlay');
    const closeBtn = this.modal.querySelector('.close-btn');
    const closeBtnFooter = this.modal.querySelector('.close-btn-footer');
    const copyableValues = this.modal.querySelectorAll('.property-value[data-copy]');

    overlay?.addEventListener('click', () => this.close());
    closeBtn?.addEventListener('click', () => this.close());
    closeBtnFooter?.addEventListener('click', () => this.close());

    // Copy on click
    copyableValues.forEach(el => {
      el.addEventListener('click', async () => {
        const value = el.dataset.copy;
        await navigator.clipboard.writeText(value);
        this.showToast('Copied!', 'success');
      });

      // Long press for full path
      let longPressTimer;
      el.addEventListener('mousedown', () => {
        longPressTimer = setTimeout(async () => {
          const value = el.dataset.copy;
          await navigator.clipboard.writeText(value);
          this.showToast('Full value copied!', 'success');
        }, 800);
      });
      el.addEventListener('mouseup', () => clearTimeout(longPressTimer));
      el.addEventListener('mouseleave', () => clearTimeout(longPressTimer));
    });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') this.close();
    });
  }

  /**
   * Get file type from extension
   */
  getFileType(filename) {
    const ext = filename.split('.').pop().toLowerCase();
    const types = {
      js: 'JavaScript',
      ts: 'TypeScript',
      html: 'HTML',
      css: 'CSS',
      json: 'JSON',
      md: 'Markdown',
      py: 'Python',
      png: 'PNG Image',
      jpg: 'JPEG Image',
      jpeg: 'JPEG Image',
      gif: 'GIF Image',
      svg: 'SVG Image',
      pdf: 'PDF Document',
      txt: 'Text File'
    };
    return types[ext] || `${ext.toUpperCase()} File`;
  }

  /**
   * Format bytes
   */
  formatBytes(bytes) {
    if (!bytes || bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  /**
   * Format date
   */
  formatDate(isoString) {
    return new Date(isoString).toLocaleString();
  }

  /**
   * Close dialog
   */
  close() {
    this.modal?.remove();
    this.modal = null;
  }

  /**
   * Show toast
   */
  showToast(message, type) {
    if (window.workspace?.showToast) {
      window.workspace.showToast(message, type);
    } else {
      console.log(`[${type}] ${message}`);
    }
  }
}

