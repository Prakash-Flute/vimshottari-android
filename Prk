/**
 * Viewport Stability Controller
 * Prevents automatic zoom and maintains desktop layout on mobile
 */

class ViewportStabilityController {
  constructor() {
    this.metaViewport = null;
    this.initialized = false;
  }

  /**
   * Initialize viewport stability controls
   */
  init() {
    if (this.initialized) return;

    this.setupViewportMeta();
    this.preventInputZoom();
    this.preventDoubleTapZoom();
    this.preventGestureZoom();
    this.lockDesktopLayout();

    this.initialized = true;
  }

  /**
   * Setup viewport meta tag
   */
  setupViewportMeta() {
    // Find existing viewport meta or create new one
    this.metaViewport = document.querySelector('meta[name="viewport"]');
    
    if (!this.metaViewport) {
      this.metaViewport = document.createElement('meta');
      this.metaViewport.name = 'viewport';
      document.head.appendChild(this.metaViewport);
    }

    // Set strict viewport properties
    this.metaViewport.content = 
      'width=device-width, ' +
      'initial-scale=1.0, ' +
      'maximum-scale=1.0, ' +
      'minimum-scale=1.0, ' +
      'user-scalable=no, ' +
      'viewport-fit=cover';
  }

  /**
   * Prevent zoom on input focus
   */
  preventInputZoom() {
    // Add touch-action CSS to all inputs
    const style = document.createElement('style');
    style.textContent = `
      input, textarea, select {
        touch-action: manipulation;
        font-size: 16px !important;
      }
      
      @media screen and (max-width: 768px) {
        input, textarea, select {
          font-size: 16px !important;
        }
      }
    `;
    document.head.appendChild(style);

    // Prevent zoom on focus
    document.addEventListener('focusin', (e) => {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
        e.target.style.fontSize = '16px';
      }
    }, { passive: true });
  }

  /**
   * Prevent double-tap zoom
   */
  preventDoubleTapZoom() {
    let lastTouchEnd = 0;

    document.addEventListener('touchend', (e) => {
      const now = Date.now();
      if (now - lastTouchEnd <= 300) {
        e.preventDefault();
      }
      lastTouchEnd = now;
    }, { passive: false });

    // Also prevent on specific elements
    document.addEventListener('touchstart', (e) => {
      if (e.touches.length > 1) {
        e.preventDefault();
      }
    }, { passive: false });
  }

  /**
   * Prevent gesture zoom
   */
  preventGestureZoom() {
    document.addEventListener('gesturestart', (e) => {
      e.preventDefault();
    }, { passive: false });

    document.addEventListener('gesturechange', (e) => {
      e.preventDefault();
    }, { passive: false });

    document.addEventListener('gestureend', (e) => {
      e.preventDefault();
    }, { passive: false });

    // Prevent pinch zoom
    document.addEventListener('touchmove', (e) => {
      if (e.touches.length > 1) {
        e.preventDefault();
      }
    }, { passive: false });
  }

  /**
   * Lock desktop layout
   */
  lockDesktopLayout() {
    const style = document.createElement('style');
    style.textContent = `
      /* Force desktop layout */
      html {
        min-width: 1024px !important;
      }
      
      body {
        min-width: 1024px !important;
        overflow-x: auto !important;
      }
      
      /* Prevent layout shifts */
      .app-container {
