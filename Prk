/**
 * GitHub Auth Service
 * Handles GitHub API authentication and token management
 */

const fs = require('fs-extra');
const path = require('path');
const axios = require('axios');

const CONFIG_DIR = path.join(__dirname, '../../config');
const TOKEN_PATH = path.join(CONFIG_DIR, 'github-token.json');

class GitHubAuthService {
  constructor() {
    this.token = null;
    this.username = null;
    this.initialized = false;
  }

  /**
   * Initialize the service and load stored token
   */
  async initialize() {
    try {
      if (await fs.pathExists(TOKEN_PATH)) {
        const data = await fs.readJson(TOKEN_PATH);
        this.token = data.token;
        this.username = data.username;
        this.initialized = true;
        return true;
      }
      return false;
    } catch (error) {
      console.error('Failed to initialize GitHub auth:', error);
      return false;
    }
  }

  /**
   * Set authentication token
   */
  async setToken(token, username) {
    this.token = token;
    this.username = username;
    this.initialized = true;
    
    await fs.ensureDir(CONFIG_DIR);
    await fs.writeJson(TOKEN_PATH, { token, username, createdAt: new Date().toISOString() });
    return true;
  }

  /**
   * Get auth headers for API requests
   */
  getHeaders() {
    if (!this.token) {
      throw new Error('GitHub not authenticated');
    }
    return {
      'Authorization': `token ${this.token}`,
      'Accept': 'application/vnd.github.v3+json',
      'User-Agent': 'GitHub-File-Manager'
    };
  }

  /**
   * Check if authenticated
   */
  isAuthenticated() {
    return this.initialized && this.token !== null;
  }

  /**
   * Get authenticated user info
   */
  async getUser() {
    if (!this.isAuthenticated()) {
      throw new Error('GitHub not authenticated');
    }
    
    const response = await axios.get('https://api.github.com/user', {
      headers: this.getHeaders()
    });
    
    return response.data;
  }

  /**
   * Clear authentication
   */
  async logout() {
    this.token = null;
    this.username = null;
    this.initialized = false;
    
    if (await fs.pathExists(TOKEN_PATH)) {
      await fs.remove(TOKEN_PATH);
    }
    
    return true;
  }
}

module.exports = new GitHubAuthService();

