/**
 * Delete Stability Handler
 * Ensures delete operations work reliably without errors
 */

class DeleteStabilityHandler {
  constructor() {
    this.deleteQueue = [];
    this.isProcessing = false;
    this.retryAttempts = 3;
    this.retryDelay = 1000;
  }

  /**
   * Queue a delete operation
   */
  async queueDelete(deleteFn, options = {}) {
    const deleteId = `delete_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
    
    const deleteOp = {
      id: deleteId,
      fn: deleteFn,
      options,
      attempts: 0,
      status: 'pending'
    };

    this.deleteQueue.push(deleteOp);
    this.processQueue();

    return deleteId;
  }

  /**
   * Process delete queue
   */
  async processQueue() {
    if (this.isProcessing || this.deleteQueue.length === 0) return;

    this.isProcessing = true;

    const operation = this.deleteQueue[0];
    operation.status = 'processing';
    operation.attempts++;

    try {
      await operation.fn();
      operation.status = 'completed';
      this.deleteQueue.shift();
      
      if (operation.options.onSuccess) {
        operation.options.onSuccess();
      }
    } catch (error) {
      console.error('Delete operation failed:', error);

      if (operation.attempts < this.retryAttempts) {
        operation.status = 'retrying';
        await this.delay(this.retryDelay * operation.attempts);
      } else {
        operation.status = 'failed';
        this.deleteQueue.shift();
        
        if (operation.options.onError) {
          operation.options.onError(error);
        }
      }
    } finally {
      this.isProcessing = false;
      this.processQueue();
    }
  }

  /**
   * Delete file from GitHub with stability handling
   */
  async deleteGitHubFile(owner, repo, path, sha, options = {}) {
    return this.queueDelete(async () => {
      // First, verify the file still exists and get current SHA
      let currentSha = sha;
      
      if (!currentSha) {
        try {
          const shaResult = await githubApi.getFileSha(owner, repo, path);
          currentSha = shaResult.sha;
        } catch (error) {
          // File might already be deleted
          if (error.message?.includes('404')) {
            return { success: true, message: 'File already deleted' };
          }
          throw error;
        }
      }

      // Perform delete
      const result = await githubApi.deleteFile(
        owner,
        repo,
        path,
        currentSha,
        options.message || `Delete ${path} via file manager`
      );

      return result;
    }, options);
  }

  /**
   * Delete file from storage with stability handling
   */
  async deleteStorageFile(fileInfo, options = {}) {
    return this.queueDelete(async () => {
      const sessionId = window.workspace?.currentSession?.id;
      if (!sessionId) {
        throw new Error('No active session');
      }

      const response = await fetch(
        `/api/sessions/${sessionId}/files/${encodeURIComponent(fileInfo.name)}`,
        { method: 'DELETE' }
      );

      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.message || 'Delete failed');
      }

      return await response.json();
    }, options);
  }

  /**
   * Get queue status
   */
  getQueueStatus() {
    return {
      pending: this.deleteQueue.filter(op => op.status === 'pending').length,
      processing: this.deleteQueue.filter(op => op.status === 'processing').length,
      retrying: this.deleteQueue.filter(op => op.status === 'retrying').length,
      total: this.deleteQueue.length
    };
  }

  /**
   * Clear completed operations from queue
   */
  clearCompleted() {
    this.deleteQueue = this.deleteQueue.filter(op => 
      op.status === 'pending' || op.status === 'processing' || op.status === 'retrying'
    );
  }

  /**
   * Delay helper
   */
  delay(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
}

// Export singleton
const deleteStability = new DeleteStabilityHandler();

