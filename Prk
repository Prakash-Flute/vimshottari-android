  /**
   * Basic JavaScript highlighting
   */
  highlightJavaScript(container) {
    const keywords = ['const', 'let', 'var', 'function', 'class', 'import', 'export', 'from', 'return', 'if', 'else', 'for', 'while', 'async', 'await'];
    const lines = container.querySelectorAll('.code-line');
    
    lines.forEach(line => {
      const content = line.querySelector('.line-content');
      if (!content) return;
      
      let html = content.innerHTML;
      
      // Keywords
      keywords.forEach(kw => {
        const regex = new RegExp(`\\b${kw}\\b`, 'g');
        html = html.replace(regex, `<span class="keyword">${kw}</span>`);
      });
      
      // Strings
      html = html.replace(/(".*?"|'.*?'|`.*?`)/g, '<span class="string">$1</span>');
      
      // Comments
      html = html.replace(/(\/\/.*$)/gm, '<span class="comment">$1</span>');
      
      content.innerHTML = html;
    });
  }

  /**
   * Basic HTML highlighting
   */
  highlightHTML(container) {
    const lines = container.querySelectorAll('.code-line');
    
    lines.forEach(line => {
      const content = line.querySelector('.line-content');
      if (!content) return;
      
      let html = content.innerHTML;
      
      // Tags
      html = html.replace(/(&lt;\/?[\w-]+)/g, '<span class="tag">$1</span>');
      // Attributes
      html = html.replace(/\s([\w-]+)=/g, ' <span class="attr">$1</span>=');
      // Strings
      html = html.replace(/(".*?")/g, '<span class="string">$1</span>');
      
      content.innerHTML = html;
    });
  }

  /**
   * Basic CSS highlighting
   */
  highlightCSS(container) {
    const lines = container.querySelectorAll('.code-line');
    
    lines.forEach(line => {
      const content = line.querySelector('.line-content');
      if (!content) return;
      
      let html = content.innerHTML;
      
      // Selectors
      html = html.replace(/^([\.#]?[\w-]+)/, '<span class="selector">$1</span>');
      // Properties
      html = html.replace(/([\w-]+):/g, '<span class="property">$1</span>:');
      // Values
      html = html.replace(/:\s*([^;]+)/g, ': <span class="value">$1</span>');
      
      content.innerHTML = html;
    });
