<div id="form-section" class="glass-card form-container">
    <form method="post" onsubmit="showLoading()" id="dashaForm">
        <!-- CITY SEARCH -->
        <div class="input-group" style="grid-column: 1 / -1; margin-bottom: 15px;">
            <label style="color: var(--accent-gold); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; display: flex; align-items: center; gap: 8px;">
                <span>🌍</span> Search Any City Worldwide
            </label>
            <div style="position: relative; display: flex; gap: 10px; flex-wrap: wrap; align-items: stretch;">
                <div style="flex: 1; position: relative; min-width: 250px;">
                    <input type="text" id="citySearch" placeholder="e.g. Mumbai, New York, London, Tokyo..." 
                           style="width: 100%; border-color: rgba(255, 215, 0, 0.3); font-size: 1rem; padding: 14px 16px;"
                           autocomplete="off">
                    <div id="cityDropdown" style="display: none; position: absolute; top: 100%; left: 0; right: 0; background: rgba(10, 10, 15, 0.95); border: 1px solid rgba(255, 215, 0, 0.3); border-top: none; border-radius: 0 0 12px 12px; max-height: 300px; overflow-y: auto; z-index: 9999; box-shadow: 0 10px 30px rgba(0,0,0,0.8); backdrop-filter: blur(10px);"></div>
                </div>
                <button type="button" onclick="searchCity()" class="btn-primary" 
                        style="width: auto; padding: 14px 30px; margin: 0; background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(255,140,0,0.1)); border-color: rgba(255,215,0,0.4); color: #ffd700;">
                    <span>🔍</span> FIND
                </button>
            </div>
            <div id="search-status" style="margin-top: 8px; font-size: 0.8rem; color: var(--text-secondary); display: none; font-family: Orbitron;"></div>
        </div>

        <div class="input-grid">
            <div class="input-group">
                <label>📅 Birth Date</label>
                <input type="date" name="dob" value="{{ form_data.dob|default('', true) }}" required>
            </div>
            <div class="input-group">
                <label>🕐 Birth Time</label>
                <input type="time" name="tob" value="{{ form_data.tob|default('', true) }}" step="1" required>
            </div>
            <div class="input-group">
                <label>🌍 Latitude</label>
                <input type="number" name="lat" step="0.000001" placeholder="28.6139" 
                       value="{{ form_data.lat|default('', true) }}" required id="inputLat">
            </div>
            <div class="input-group">
                <label>🌐 Longitude</label>
                <input type="number" name="lon" step="0.000001" placeholder="77.2090" 
                       value="{{ form_data.lon|default('', true) }}" required id="inputLon">
            </div>
            <div class="input-group">
                <label>⏰ Timezone (UTC)</label>
                <input type="number" name="tz" step="0.1" placeholder="+5.5" 
                       value="{{ form_data.tz|default('', true) }}" required id="inputTz">
            </div>
            <div class="input-group">
                <label>🎯 Target Date</label>
                <input type="date" name="target" value="{{ form_data.target|default('', true) }}" required id="inputTarget">
            </div>
        </div>
        
        <!-- GPS BUTTON -->
        <div class="input-group" style="grid-column: 1 / -1; display: flex; justify-content: center; margin: 15px 0;">
            <button type="button" onclick="getPreciseLocation()" class="btn-primary" style="max-width: 320px; background: linear-gradient(135deg, rgba(0,255,136,0.1), rgba(0,217,255,0.1)); border-color: rgba(0,255,136,0.4); color: #00ff88; display: inline-flex; align-items: center; gap: 8px; font-size: 0.9rem;">
                <span style="font-size: 1.2rem;">📍</span> Use My Exact Location (GPS)
            </button>
        </div>
        <div id="gps-status" style="grid-column: 1 / -1; text-align: center; color: #00ff88; font-family: Orbitron; font-size: 0.8rem; display: none; margin-bottom: 10px;">
            🎯 High Precision GPS Locked
        </div>

        <button type="submit" class="btn-primary" id="submit-btn">✨ Calculate Dasha</button>
        <a href="{{ url_for('vimshottari') }}" class="btn-secondary-form">📝 New Query</a>
    </form>
</div>
<!-- Add this at the bottom of form_section.html -->
<script>
// HIGH PRECISION GPS FUNCTION
function getPreciseLocation() {
    const btn = event.target.closest('button');
    const statusDiv = document.getElementById('gps-status');
    const origHTML = btn.innerHTML;
    
    btn.innerHTML = '<span style="display:inline-block; animation: pulse 1s infinite;">📡</span> ACQUIRING SATELLITES...';
    btn.disabled = true;
    
    if (!navigator.geolocation) {
        alert("❌ Geolocation not supported by browser");
        btn.innerHTML = origHTML;
        btn.disabled = false;
        return;
    }
    
    const options = {
        enableHighAccuracy: true,
        timeout: 30000,
        maximumAge: 0
    };
    
    navigator.geolocation.getCurrentPosition(
        function(pos) {
            const lat = pos.coords.latitude;
            const lon = pos.coords.longitude;
            const acc = pos.coords.accuracy;
            
            // Update coordinates
            document.getElementById('inputLat').value = lat.toFixed(6);
            document.getElementById('inputLon').value = lon.toFixed(6);
            
            // YE RAHSA FIX: Proper timezone calculation
            let tz = (lon / 15).toFixed(1);
            // Agar .0 hai toh hata do (5.0 -> 5), warna rakho (5.5)
            if (tz.endsWith('.0')) {
                tz = parseInt(tz);
            }
            
            // INDIA SPECIAL CASE: Agar roughly India mein ho toh 5.5 force kar do
            // (India: Lat 8-37°N, Lon 68-97°E)
            if (lat > 8 && lat < 37 && lon > 68 && lon < 97) {
                tz = 5.5;
                console.log('🇮🇳 India detected! Setting timezone to 5.5');
            }
            
            document.getElementById('inputTz').value = tz;
            
            // Visual feedback
            btn.innerHTML = '<span>✅</span> LOCKED (±' + Math.round(acc) + 'm)';
            btn.style.borderColor = '#00ff88';
            btn.style.color = '#00ff88';
            if(statusDiv) {
                statusDiv.innerHTML = '🎯 GPS: ' + lat.toFixed(4) + '°N, ' + lon.toFixed(4) + '°E | TZ: UTC+' + tz;
                statusDiv.style.display = 'block';
            }
            
            setTimeout(() => {
                btn.innerHTML = origHTML;
                btn.disabled = false;
                btn.style.borderColor = '';
                btn.style.color = '';
            }, 4000);
        },
        function(err) {
            let msg = "GPS Error";
            switch(err.code) {
                case 1: msg = "Permission denied. Allow location access."; break;
                case 2: msg = "Position unavailable. Go outside/open sky."; break;
                case 3: msg = "Timeout. Try again in open area."; break;
            }
            alert("⚠️ " + msg);
            btn.innerHTML = origHTML;
            btn.disabled = false;
        },
        options
    );
}

// CITY SEARCH FUNCTIONS
function searchCity() {
    const query = document.getElementById('citySearch')?.value;
    if (query) performCitySearch(query);
}

async function performCitySearch(query) {
    const dropdown = document.getElementById('cityDropdown');
    const status = document.getElementById('search-status');
    
    if (!dropdown) return;
    
    dropdown.style.display = 'block';
    dropdown.innerHTML = '<div style="padding:20px; text-align:center; color:var(--accent-cyan);">🌐 Searching...</div>';
    if (status) {
        status.style.display = 'block';
        status.textContent = '🔍 Searching...';
    }
    
    try {
        const response = await fetch(`https://nominatim.openstreetmap.org/search?city=${encodeURIComponent(query)}&format=json&limit=8&accept-language=en`);
        const data = await response.json();
        
        if (!data || data.length === 0) {
            dropdown.innerHTML = '<div style="padding:20px; color:#ff4d7d;">🌍 No cities found</div>';
            if (status) status.textContent = '❌ No results';
            return;
        }
        
        let html = '';
        data.forEach(place => {
            const parts = place.display_name.split(',');
            const city = parts[0].trim();
            const country = parts[parts.length-1].trim();
            
            html += `<div onclick="selectCity(${place.lat}, ${place.lon}, '${city.replace(/'/g, "\\'")}')" 
                style="padding:14px 16px; cursor:pointer; border-bottom:1px solid rgba(255,255,255,0.08);" 
                onmouseover="this.style.background='rgba(0,217,255,0.15)'" 
                onmouseout="this.style.background='transparent'">
                <div style="font-weight:600; color:#fff;">📍 ${city}</div>
                <div style="font-size:0.75rem; color:var(--text-secondary);">${country}</div>
            </div>`;
        });
        
        dropdown.innerHTML = html;
        if (status) status.innerHTML = '<span style="color:#00ff88;">✅ Click city to select</span>';
        
    } catch (error) {
        dropdown.innerHTML = '<div style="padding:20px; color:#ff4d7d;">⚠️ Network error</div>';
    }
}

function selectCity(lat, lon, city) {
    document.getElementById('inputLat').value = parseFloat(lat).toFixed(6);
    document.getElementById('inputLon').value = parseFloat(lon).toFixed(6);
    document.getElementById('citySearch').value = city;
    document.getElementById('cityDropdown').style.display = 'none';
    
    // YE RAHSA FIX: Timezone calculation for city search
    let tz = (parseFloat(lon) / 15).toFixed(1);
    if (tz.endsWith('.0')) {
        tz = parseInt(tz);
    }
    
    // INDIA SPECIAL CASE
    const latNum = parseFloat(lat);
    const lonNum = parseFloat(lon);
    if (latNum > 8 && latNum < 37 && lonNum > 68 && lonNum < 97) {
        tz = 5.5;
    }
    
    document.getElementById('inputTz').value = tz;
    
    // Visual feedback
    const tzInput = document.getElementById('inputTz');
    tzInput.style.borderColor = '#00ff88';
    tzInput.style.boxShadow = '0 0 20px rgba(0,255,136,0.4)';
    setTimeout(() => {
        tzInput.style.borderColor = '';
        tzInput.style.boxShadow = '';
    }, 2000);
    
    const status = document.getElementById('search-status');
    if (status) {
        status.innerHTML = `<span style="color:#00ff88;">🎯 ${city} locked! TZ: UTC${tz >= 0 ? '+' : ''}${tz}</span>`;
        setTimeout(() => status.style.display = 'none', 3000);
    }
}

// Close dropdown when clicking outside
document.addEventListener('click', function(e) {
    const searchBox = document.getElementById('citySearch');
    const dropdown = document.getElementById('cityDropdown');
    if (searchBox && dropdown && !searchBox.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.style.display = 'none';
    }
});
</script>
