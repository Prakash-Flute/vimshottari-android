<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Write Article</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@700&family=Roboto:wght@300;400;700&display=swap');
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Roboto',sans-serif;background:linear-gradient(135deg,#000428,#004e92);min-height:100vh;color:#fff;display:flex;justify-content:center;align-items:center;padding:20px}
        .container{background:rgba(0,0,0,0.7);backdrop-filter:blur(15px);border-radius:20px;border:1px solid rgba(0,255,136,0.3);padding:40px;box-shadow:0 0 50px rgba(0,255,136,0.2);width:100%;max-width:900px}
        h2{font-family:'Orbitron',monospace;font-size:2em;margin-bottom:30px;background:linear-gradient(45deg,#00ff88,#00ffff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-align:center}
        .summary{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:15px;margin-bottom:30px}
        .summary-item{padding:15px;background:rgba(0,0,0,0.5);border-radius:10px;border-left:4px solid #00ff88}
        textarea{width:100%;height:400px;padding:20px;border-radius:10px;border:2px solid rgba(0,255,136,0.3);background:rgba(0,0,0,0.5);color:#fff;font-size:1em;resize:vertical}
        textarea:focus{outline:none;border-color:#00ff88;box-shadow:0 0 15px rgba(0,255,136,0.5)}
        button{width:100%;padding:18px;background:linear-gradient(45deg,#00ff88,#00ffff);border:none;border-radius:10px;font-size:1.2em;font-weight:bold;color:#000;cursor:pointer;transition:all .3s;text-transform:uppercase;letter-spacing:2px;margin-top:20px}
        button:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(0,255,136,0.5)}
    </style>
</head>
<body>
    <div class="container">
        <h2>COSMIC ARTICLE WRITER</h2>
        <div class="summary">
            <div class="summary-item"><strong>Ascendant:</strong> {{ ascendant }}</div>
            <div class="summary-item"><strong>House:</strong> {{ house }}</div>
            <div class="summary-item"><strong>Planet:</strong> {{ planet }}</div>
            <div class="summary-item"><strong>Aspected By:</strong> {{ aspected_by }}</div>
            <div class="summary-item"><strong>From House:</strong> {{ aspected_from_house }}</div>
            <div class="summary-item"><strong>Nakshatra:</strong> {{ nakshatra }}</div>
        </div>
        <form action="/save_article" method="POST">
            <input type="hidden" name="ascendant" value="{{ ascendant }}">
            <input type="hidden" name="house" value="{{ house }}">
            <input type="hidden" name="planet" value="{{ planet }}">
            <input type="hidden" name="aspectedBy" value="{{ aspected_by }}">
            <input type="hidden" name="aspectedFromHouse" value="{{ aspected_from_house }}">
            <input type="hidden" name="nakshatra" value="{{ nakshatra }}">
            <textarea name="article" placeholder="Channel cosmic wisdom here..." required></textarea>
            <button type="submit">Save to Universe</button>
        </form>
    </div>
</body>
</html>